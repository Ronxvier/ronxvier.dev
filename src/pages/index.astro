<script>
    const content = document.getElementById('main-content');

    if (content && window.innerWidth > 768) {
        content.addEventListener('wheel', (e) => e.preventDefault(), { passive: false });
        content.addEventListener('touchmove', (e) => e.preventDefault(), { passive: false });
    }

    document.querySelectorAll('a.nav-link').forEach((link) => {
        link.addEventListener('click', (e) => {
            const hash = link.getAttribute('href');
            if (!hash || !hash.startsWith('#')) return;
            e.preventDefault();
            const target = document.querySelector(hash);
            if (target) {
                target.scrollIntoView({ behavior: 'smooth' });
            }
        });
    });
</script>

<style is:global>
    html, body {
        height: 100%;
        overflow: hidden;
        margin: 0;
    }
    @media (max-width: 768px) {
        html, body {
            height: auto;
            overflow: auto;
        }
    }
</style>

<style>
    .layout-container {
        display: flex;
        flex-direction: row;
        height: 100vh;
    }

    .sidebar {
        height: 100vh;
        padding-left: 1rem;
        padding-right: 2rem;
        min-width: 200px;
        flex-shrink: 0;
    }

    .internal-container {
        padding-top: 1rem;
        display: flex;
        gap: 0.2rem;
        flex-direction: column;
    }

    .content {
        flex: 1;
        overflow-y: scroll;
        height: 100vh;
        scrollbar-width: none;
    }
    .content::-webkit-scrollbar {
        display: none;
    }

    .section {
        min-height: 100vh;
        padding-top: 3rem;
        padding-bottom: 3rem;
        padding-right: 3.5rem;
    }

    .padded {
        padding-top: 1rem;
        padding-bottom: 0.2rem;
    }

    .project-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        padding-left: 1.2rem;
    }

    .list-container {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .projectlink {
        text-decoration: none;
        font-weight: bold;
        color: #C4714E;
    }
    .projectlink:hover {
        background-color: #E8E1D8;
        color: #A05535;
    }

    .archivelink {
        color: #C4714E;
        font-weight: bold;
        text-decoration: none;
    }
    .archivelink:hover {
        color: #A05535;
        background-color: #E8E1D8;
    }

    @media (max-width: 768px) {
        .layout-container {
            flex-direction: column;
            height: auto;
        }
        .sidebar {
            position: sticky;
            top: 0;
            z-index: 10;
            height: auto;
            min-width: auto;
            padding: 0.75rem 1rem;
            background-color: #F2EDE5;
            border-bottom: 1px solid #E0D8CE;
        }
        .signature-container {
            display: none;
        }
        .internal-container {
            flex-direction: row;
            flex-wrap: wrap;
            gap: 0.5rem;
            padding-top: 0;
        }
        .content {
            overflow-y: visible;
            height: auto;
            padding-left: 1rem;
            padding-right: 1rem;
        }
        .section {
            padding-right: 0;
            min-height: 100vh;
            padding-bottom: 3rem;
        }
    }
</style>
