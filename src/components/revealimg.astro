<div class="reveal" id="reveal">
  <img class="lowres" src="/PixelZNFP.png" alt="">
  <img class="hires" src="/ZNFP.png" alt="">
  <div class="tracker-box" id="tracker-box"></div>
  <div class="coord-label" id="coord-label"></div>
  <div class="reveal-caption">
    <h1 class="reveal-title">Home</h1>
    <p class="reveal-body">
      Welcome to my dev portfolio! I use this website to keep track of my
      projects and write small
      <a href="#archive" class="reveal-link nav-link">[blog]</a>
      sections.
    </p>
  </div>
</div>

<style>
  .reveal { position: relative; cursor: crosshair; width: 100%; aspect-ratio: 16 / 9; }
  .reveal img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; border-radius: 15px;}
  .hires {
    /* start fully clipped away (empty box) */
    clip-path: inset(50% 50% 50% 50%);
  }
  .tracker-box{
    position: absolute;
    box-sizing: border-box;
    border:0.2px solid #faf5f2;
    opacity: 0;
    pointer-events: none;
  }

  .coord-label {
    position: absolute;
    transform: translateY(calc(-100% - 8px));
    font-family: "JetBrains Mono", monospace;
    font-weight: 100;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    color: #faf5f2;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.6);
    opacity: 0;
    pointer-events: none;
    white-space: nowrap;
  }

  .reveal-caption {
    position: absolute;
    left: 1.5rem;
    bottom: 1.5rem;
    max-width: 60%;
    text-align: left;
    pointer-events: none;
  }

  .reveal-title {
    margin: 0;
    color: #faf5f2;
    font-family: "Libre Baskerville", serif;
    font-style: italic;
    font-weight: 400;
    font-size: 2.75rem;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
  }

  .reveal-body {
    margin: 0.35rem 0 0;
    color: #faf5f2;
    font-family: "JetBrains Mono", monospace;
    font-size: 1.05rem;
    line-height: 1.4;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.8);
  }

  .reveal-link {
    color: #C4714E;
    font-weight: bold;
    text-decoration: none;
    pointer-events: auto;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.8);
  }
  .reveal-link:hover {
    color: #ffffff;
  }

  @media (max-width: 768px) {
    .reveal-caption {
      left: 1rem;
      bottom: 1rem;
      max-width: 75%;
    }
    .reveal-title {
      font-size: 1.6rem;
    }
    .reveal-body {
      font-size: 0.85rem;
    }
  }
</style>

<script>
  import { animate } from 'animejs';

  const reveal = document.getElementById('reveal');
  const hires = reveal.querySelector('.hires');
  const trackerBox = document.getElementById('tracker-box');
  const coordLabel = document.getElementById('coord-label');
  const BOXht = 240; // px, size of the reveal window (height)
  const BOXwd = 180; // px, size of the reveal window (width)

  trackerBox.style.width = `${BOXwd}px`;
  trackerBox.style.height = `${BOXht}px`;

  reveal.addEventListener('mousemove', (e) => {
    const r = reveal.getBoundingClientRect();
    const x = e.clientX - r.left;
    const y = e.clientY - r.top;
    const halfW = BOXwd / 2;
    const halfH = BOXht / 2;

    // inset() = distance from top, right, bottom, left edges
    const top = y - halfH;
    const right = r.width - (x + halfW);
    const bottom = r.height - (y + halfH);
    const left = x - halfW;

    animate(hires, {
      clipPath: `inset(${top}px ${right}px ${bottom}px ${left}px)`,
      duration: 150,
      ease: 'outBack',
      delay:7,
    });

    animate(trackerBox, {
      left: `${left}px`,
      top: `${top}px`,
      duration: 150,
      ease: 'outBack',
      delay: 7,
    });

    // higher on the image = higher degreeN
    const north = ((r.height - y) / r.height) * 90; // get height like degrees
    const clamped = Math.max(0, Math.min(90, north)); // clamp it between 0 and 90
coordLabel.textContent = `${clamped.toFixed(4)}°N`; // fix to 4 decimal

    animate(coordLabel, {
      left: `${left}px`,
      top: `${top}px`,
      duration: 150,
      ease: 'outBack', // need to experiment with other curves
      delay: 7,
    });
  });

  reveal.addEventListener('mouseleave', () => {
    animate(hires, {
      opacity: 0,
      duration: 500,
      ease: 'outBack',
    });
    animate(trackerBox, {
      opacity: 0,
      duration: 500,
      ease: 'outBack',
    });
    animate(coordLabel, {
      opacity: 0,
      duration: 500,
      ease: 'outBack',
    });
  });
reveal.addEventListener('mouseenter', () => {
  // needs to re-enter @ opacity 1 after fadeout
  animate(hires, { opacity: 1, duration: 100, ease: 'outQuad' });
  animate(trackerBox, { opacity: 1, duration: 100, ease: 'outQuad' });
  animate(coordLabel, { opacity: 1, duration: 100, ease: 'outQuad' });
});
</script>
